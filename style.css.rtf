\}\
\
.socials a \{\
    font-size: 20px;\
    margin: 10px;\
    color: #d4a24c;\
    border: 1px solid #d4a24c;\
    padding: 12px;\
    border-radius: 50%;\
\}\
\
.socials a:hover \{\
    background: #d4a24c;\
    color: black;\
\}\
\
/* LIGHTBOX */\
#lightbox \{\
    display: none;\
    position: fixed;\
    top:0;\
    left:0;\
    width:100%;\
    height:100%;\
    background: rgba(0,0,0,0.9);\
    justify-content:center;\
    align-items:center;\
\}\
\
#lightbox img \{\
    max-width:90%;\
    max-height:90%;\
\}\
\
/* ANIMATION */\
@keyframes fadeIn \{\
    from \{ opacity: 0; transform: translateY(20px);\}\
    to \{ opacity: 1; transform: translateY(0);\}\
\}}