\f0\fs24 \cf0 body \{\
    margin: 0;\
    font-family: 'Montserrat', sans-serif;\
    background: #000;\
    color: #fff;\
\}\
\
/* HERO */\
.hero \{\
    position: relative;\
    height: 100vh;\
    background: url('images/img1.jpg') center/cover no-repeat;\
    display: flex;\
    justify-content: center;\
    align-items: center;\
    text-align: center;\
\}\
\
.overlay \{\
    position: absolute;\
    width: 100%;\
    height: 100%;\
    background: rgba(0,0,0,0.6);\
\}\
\
.hero-content \{\
    position: relative;\
    z-index: 2;\
    animation: fadeIn 1.5s ease-in-out;\
\}\
\
.logo \{\
    max-width: 250px;\
    margin-bottom: 20px;\
\}\
\
.hero h1 \{\
    font-family: 'Playfair Display', serif;\
    font-size: 40px;\
    color: #d4a24c;\
    margin: 0;\
\}\
\
.hero p \{\
    font-size: 18px;\
\}\
\
/* GALLERY */\
.gallery \{\
    padding: 60px 20px;\
    text-align: center;\
\}\
\
.gallery h2 \{\
    color: #d4a24c;\
    margin-bottom: 30px;\
\}\
\
.grid \{\
    display: grid;\
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\
    gap: 12px;\
\}\
\
.grid img \{\
    width: 100%;\
    border-radius: 10px;\
    cursor: pointer;\
    transition: transform 0.4s, opacity 0.4s;\
\}\
\
.grid img:hover \{\
    transform: scale(1.05);\
    opacity: 0.85;\
\}\
\
/* CONTACT */\
.contact \{\
    padding: 60px 20px;\
    text-align: center;\
\}\
\
.contact a \{\
    color: #d4a24c;\
    text-decoration: none;\
\}\
\
.socials \{\
